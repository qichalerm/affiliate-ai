# =============================================================================
# Shopee Affiliate AI System — Environment Variables
# =============================================================================
# This is the TEMPLATE file. Copy to .env and fill in real values.
# Variables grouped by Layer (see system architecture).
# =============================================================================


# -----------------------------------------------------------------------------
# CORE / GENERAL
# -----------------------------------------------------------------------------

# Domain ของเว็บ aggregator (ไม่ต้องใส่ https://)
DOMAIN_NAME=yourdomain.com

# Environment
NODE_ENV=development                  # development | staging | production
LOG_LEVEL=info                        # debug | info | warn | error
TIMEZONE=Asia/Bangkok

# Operator info (ใช้ส่ง alert)
OPERATOR_EMAIL=
OPERATOR_PHONE=


# -----------------------------------------------------------------------------
# LAYER 0: AFFILIATE PROGRAMS
# -----------------------------------------------------------------------------

# Shopee Affiliate (สมัคร: https://affiliate.shopee.co.th/)
SHOPEE_AFFILIATE_ID=                  # affiliate ID หลังสมัครเสร็จ
SHOPEE_AFFILIATE_USERNAME=
SHOPEE_AFFILIATE_PASSWORD=            # ใช้สำหรับ scrape dashboard (Layer 7)
SHOPEE_API_KEY=                       # ถ้าได้รับสิทธิ์เข้า Marketing Solutions API
SHOPEE_API_SECRET=
SHOPEE_TRACKING_ID=                   # custom sub-id สำหรับ track conversion

# Lazada Affiliate (optional, สำหรับ price comparison)
LAZADA_AFFILIATE_ID=
LAZADA_API_KEY=
LAZADA_API_SECRET=

# TikTok Shop Affiliate (optional, แยกจาก Shopee)
TIKTOK_SHOP_AFFILIATE_ID=
TIKTOK_SHOP_API_KEY=


# -----------------------------------------------------------------------------
# LAYER 1: DATA / DATABASE
# -----------------------------------------------------------------------------

# Postgres — primary database
# Default: self-host on DigitalOcean Droplet (run scripts/setup-postgres.sh)
# Alternative: Neon free tier (https://neon.tech)
# Self-host (localhost):  postgresql://botuser:PASS@localhost:5432/affiliate?sslmode=disable
# Neon:                   postgresql://user:PASS@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://placeholder:placeholder@localhost/placeholder
DATABASE_POOL_SIZE=10

# DigitalOcean Spaces (optional — for off-site DB backups)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=affiliate-backups

# Redis (cache + queue) — Upstash หรือ self-host
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=                          # ถ้าใช้ Upstash

# DuckDB / ClickHouse (analytics warehouse) — optional Phase 4
ANALYTICS_DB_URL=


# -----------------------------------------------------------------------------
# LAYER 2: CONTENT GENERATION (AI)
# -----------------------------------------------------------------------------

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=                    # ใช้ Claude Haiku 4.5 + Sonnet 4.6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001     # 95% ของงาน — verdict, SEO meta, bulk
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6            # 4% — comparison, ranking, edge cases
ANTHROPIC_MODEL_PRO=claude-opus-4-7                # 1% — story, weekly insights, strategic
ANTHROPIC_PRO_THINKING_BUDGET=8000                 # extended thinking tokens for Opus tasks

# OpenAI (backup, optional)
OPENAI_API_KEY=

# ElevenLabs (voice) — https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                  # voice clone ID หลัง upload เสียงตัวเอง
ELEVENLABS_MODEL=eleven_multilingual_v3

# Image generation (Flux Pro หรือ Replicate)
FLUX_API_KEY=
REPLICATE_API_TOKEN=                  # alternative for Flux

# Video generation (สำหรับฉาก ambient — optional)
SORA_API_KEY=                         # OpenAI Sora 2
KLING_API_KEY=                        # Kuaishou Kling
RUNWAY_API_KEY=

# Captions (Submagic)
SUBMAGIC_API_KEY=

# Music generation (optional)
SUNO_API_KEY=
MUBERT_API_KEY=


# -----------------------------------------------------------------------------
# LAYER 3: WEB / DEPLOYMENT
# -----------------------------------------------------------------------------

# Cloudflare (https://dash.cloudflare.com)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=                 # ต้องมี permission: Pages:Edit, R2:Edit, DNS:Edit
CLOUDFLARE_ZONE_ID=                   # หลังเพิ่มโดเมนใน Cloudflare
CLOUDFLARE_PAGES_PROJECT=shopee-aggregator

# Cloudflare R2 (image/asset storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=affiliate-assets

# GitHub (auto-deploy Pages)
GITHUB_TOKEN=                         # personal access token
GITHUB_REPO=username/repo-name


# -----------------------------------------------------------------------------
# LAYER 3: SEARCH / SEO
# -----------------------------------------------------------------------------

# Google Search Console + Indexing API
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/google-service-account.json
GOOGLE_SEARCH_CONSOLE_PROPERTY=https://yourdomain.com/

# Bing IndexNow
BING_INDEXNOW_KEY=                    # generate ที่ bing.com/indexnow

# Ahrefs / SEMrush (optional, สำหรับ keyword research)
AHREFS_API_TOKEN=
SEMRUSH_API_KEY=


# -----------------------------------------------------------------------------
# LAYER 3: SOCIAL MEDIA APIS
# -----------------------------------------------------------------------------

# TikTok Content Posting API (https://developers.tiktok.com)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=                  # OAuth long-lived token
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# TikTok บัญชีเสริม (multi-account farming)
TIKTOK_ACCOUNT_2_ACCESS_TOKEN=
TIKTOK_ACCOUNT_3_ACCESS_TOKEN=

# Meta (Facebook + Instagram) — https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=                         # FB Page ที่จะโพสต์
META_PAGE_ACCESS_TOKEN=               # long-lived page token
META_INSTAGRAM_BUSINESS_ID=           # IG account (must connect to FB Page)
META_AD_ACCOUNT_ID=                   # ถ้าจะยิง ad เสริม (optional)

# YouTube (Data API + Upload)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Pinterest API (https://developers.pinterest.com)
PINTEREST_ACCESS_TOKEN=
PINTEREST_AD_ACCOUNT_ID=
PINTEREST_BOARD_IDS=                  # comma-separated board IDs

# X (Twitter) API v2
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# LinkedIn (optional, B2B niche)
LINKEDIN_ACCESS_TOKEN=

# Threads (Meta) — uses same Meta Graph credentials
# Lemon8 — no public API, use Playwright (LEMON8_USERNAME/PASSWORD)
LEMON8_USERNAME=
LEMON8_PASSWORD=


# -----------------------------------------------------------------------------
# LAYER 5: MONITORING / NOTIFICATIONS
# -----------------------------------------------------------------------------

# Telegram Bot (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=                   # @BotFather
TELEGRAM_OPERATOR_CHAT_ID=            # personal chat (ส่ง alert ส่วนตัว)
TELEGRAM_DEAL_CHANNEL_ID=             # public channel (broadcast ดีล)
TELEGRAM_DEAL_CHANNEL_USERNAME=

# Sentry (error tracking)
SENTRY_DSN=

# Plausible Analytics (https://plausible.io)
PLAUSIBLE_API_KEY=
PLAUSIBLE_DOMAIN=

# UptimeRobot (https://uptimerobot.com)
UPTIMEROBOT_API_KEY=

# Email (alerts) — Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=alerts@yourdomain.com


# -----------------------------------------------------------------------------
# LAYER 8: PRODUCT INTELLIGENCE / TREND DATA
# -----------------------------------------------------------------------------

# FastMoss (TikTok product trends) — https://fastmoss.com
FASTMOSS_API_KEY=

# Kalodata (alternative TikTok analytics)
KALODATA_API_KEY=

# Google Trends — pytrends (no key) หรือ SerpAPI
SERPAPI_KEY=                          # https://serpapi.com (paid)

# Open-Meteo (weather, ฟรี)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# News RSS — list of feed URLs (comma-separated)
NEWS_RSS_FEEDS=https://www.thairath.co.th/rss/news,https://www.bangkokpost.com/rss/data/topstories.xml


# -----------------------------------------------------------------------------
# LAYER 11: COMPLIANCE / PROXY
# -----------------------------------------------------------------------------

# Webshare proxy (https://webshare.io) — residential proxy rotation
WEBSHARE_API_KEY=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST_LIST=                      # endpoint list

# BrightData (alternative)
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_HOST=

# 2Captcha (สำหรับ bypass captcha เมื่อจำเป็น — TOS-compliant use only)
TWOCAPTCHA_API_KEY=


# -----------------------------------------------------------------------------
# LINK MANAGEMENT
# -----------------------------------------------------------------------------

# Bitly (URL shortener + click tracking)
BITLY_TOKEN=
BITLY_DOMAIN=                         # custom short domain (optional)

# Short.io (alternative)
SHORTIO_API_KEY=


# -----------------------------------------------------------------------------
# DASHBOARD / AUTH
# -----------------------------------------------------------------------------

# Dashboard auth (Clerk)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Internal API secret (สำหรับ n8n เรียก dashboard backend)
INTERNAL_API_SECRET=                  # generate: openssl rand -hex 32

# Session secret
SESSION_SECRET=                       # generate: openssl rand -hex 32


# -----------------------------------------------------------------------------
# WORKFLOW / AUTOMATION
# -----------------------------------------------------------------------------

# n8n (self-hosted)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=

# Crontab schedule (override defaults if needed)
CRON_SCRAPE_PRODUCTS=0 */6 * * *      # ทุก 6 ชม.
CRON_GENERATE_PAGES=0 6 * * *         # 6 โมงเช้า
CRON_DEPLOY_SITE=0 7 * * *
CRON_SUBMIT_SITEMAP=0 9 * * *
CRON_DAILY_REPORT=0 21 * * *
CRON_HEALTH_CHECK=*/5 * * * *


# -----------------------------------------------------------------------------
# BUSINESS SETTINGS (configurable, no auth)
# -----------------------------------------------------------------------------

# Niche
PRIMARY_NICHE=it_gadget               # it_gadget | beauty | home | sports | mom_baby
SECONDARY_NICHE=

# Content strategy
POSTING_MODE=hybrid                   # full_auto | hybrid | manual_review
HUMAN_FACE_INTRO_SECONDS=7            # ถ้า hybrid mode — กี่วิที่ออกหน้าเอง

# Risk management
MAX_CHANNEL_CONCENTRATION=0.40        # ห้าม 1 channel เกิน 40% revenue
MIN_PRODUCT_RATING=4.0                # ไม่ promote สินค้า rating < 4.0
MIN_PRODUCT_SOLD=50                   # ขั้นต่ำยอดขายก่อน promote
EXCLUDE_NEW_SHOP_DAYS=180             # ร้านใหม่ < 180 วัน skip

# Budget caps
DAILY_LLM_BUDGET_USD=5
DAILY_VIDEO_GEN_BUDGET_USD=10
DAILY_PROXY_BUDGET_USD=2

# Tier targets (Shopee Affiliate tier system)
TARGET_TIER=gold                      # silver | gold | platinum
GMV_PUSH_THRESHOLD=0.80               # push hard เมื่อใกล้ tier ถัดไป


# -----------------------------------------------------------------------------
# FEATURE FLAGS (ปิด/เปิด layer แต่ละชั้น)
# -----------------------------------------------------------------------------

FEATURE_LAYER_1_DATA_COLLECTION=true
FEATURE_LAYER_2_CONTENT_GEN=true
FEATURE_LAYER_3_DISTRIBUTION=true
FEATURE_LAYER_4_OPTIMIZATION=true
FEATURE_LAYER_5_MONITORING=true
FEATURE_LAYER_6_SELF_HEALING=true
FEATURE_LAYER_7_CAMPAIGN_OPT=false    # เปิด Phase 2
FEATURE_LAYER_8_PRODUCT_INTEL=false   # เปิด Phase 2
FEATURE_LAYER_9_NARRATIVE=false       # เปิด Phase 3
FEATURE_LAYER_10_PERFORMANCE_INTEL=false  # เปิด Phase 4
FEATURE_LAYER_11_COMPLIANCE=true

FEATURE_TIKTOK_AUTO_POST=false        # เปิดเมื่อได้ TikTok API approved
FEATURE_META_AUTO_POST=false
FEATURE_PINTEREST_AUTO_POST=true
FEATURE_TELEGRAM_BROADCAST=true
FEATURE_YOUTUBE_AUTO_POST=false


# -----------------------------------------------------------------------------
# DEVELOPMENT / DEBUG
# -----------------------------------------------------------------------------

DEBUG_DRY_RUN=true                    # true = ไม่โพสต์จริง / ไม่จ่ายเงิน
DEBUG_VERBOSE_LOGGING=false
DEBUG_SAVE_INTERMEDIATE=true          # save scraped raw data + generated content for review
