# =============================================================================
# affiliate-ai V2 — Environment Variables (template)
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
DOMAIN_NAME=price-th.com
NODE_ENV=development                  # development | production
LOG_LEVEL=info                        # debug | info | warn | error
TIMEZONE=Asia/Bangkok

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://botuser:PASS@localhost:5432/affiliate?sslmode=disable
DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# AFFILIATE PROGRAMS
# -----------------------------------------------------------------------------
# Shopee Affiliate (https://affiliate.shopee.co.th/)
SHOPEE_AFFILIATE_ID=                  # affiliate ID
SHOPEE_API_KEY=                       # Marketing Solutions API (if approved)
SHOPEE_API_SECRET=
SHOPEE_TRACKING_ID=                   # custom sub-id

# TikTok Shop Affiliate (https://affiliate.tiktok.com/)
TIKTOK_SHOP_AFFILIATE_ID=
TIKTOK_SHOP_API_KEY=

# -----------------------------------------------------------------------------
# DATA SOURCES
# -----------------------------------------------------------------------------
# Apify (Shopee scraper — only working solution)
APIFY_TOKEN=
APIFY_ACTOR_SHOPEE=xtracto/shopee-scraper
APIFY_MEMORY_MB=2048
APIFY_DAILY_BUDGET_USD=2.0           # daily cap (multi-niche budget)

# -----------------------------------------------------------------------------
# AI / CONTENT GENERATION
# -----------------------------------------------------------------------------
# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001     # 80% workload
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6            # 18% — decisions, comparison
ANTHROPIC_MODEL_PRO=claude-opus-4-7                # 2% — strategic insights

# ElevenLabs (voice clone — Thai)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v3

# Image generation
REPLICATE_API_TOKEN=                  # Flux models
FLUX_API_KEY=

# Video generation
KLING_API_KEY=                        # Kuaishou Kling
SORA_API_KEY=                         # OpenAI Sora 2
RUNWAY_API_KEY=

# Captions
SUBMAGIC_API_KEY=

# -----------------------------------------------------------------------------
# WEB / DEPLOYMENT
# -----------------------------------------------------------------------------
# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=                 # Pages:Edit + R2:Edit + DNS:Edit
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PAGES_PROJECT=affiliate-ai

# Cloudflare R2 (asset storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=affiliate-assets

# GitHub
GITHUB_TOKEN=
GITHUB_REPO=

# -----------------------------------------------------------------------------
# SEO
# -----------------------------------------------------------------------------
# Google Search Console (OAuth refresh token — works around org policy)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_SEARCH_CONSOLE_PROPERTY=sc-domain:price-th.com

# Bing IndexNow
BING_INDEXNOW_KEY=

# -----------------------------------------------------------------------------
# SOCIAL — V2 channels only
# -----------------------------------------------------------------------------
# Meta (Facebook + Instagram) — Graph API
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=               # long-lived
META_INSTAGRAM_BUSINESS_ID=

# TikTok Content Posting API (1 account, full auto)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# -----------------------------------------------------------------------------
# OPERATIONS
# -----------------------------------------------------------------------------
# Email (operator alerts only — NOT marketing)
RESEND_API_KEY=
EMAIL_FROM=alerts@price-th.com
OPERATOR_EMAIL=

# Sentry (error tracking)
SENTRY_DSN=

# -----------------------------------------------------------------------------
# NICHE / SCRAPE TUNING
# -----------------------------------------------------------------------------
# Multi-niche scrape (V2: all niches, AI rotates budget)
PRIMARY_NICHE=all                     # all | it_gadget | beauty | home | sports | mom_baby | food_kitchen | fashion | car_garage
SCRAPE_KEYWORDS_PER_RUN=4
SCRAPE_PRODUCTS_PER_KEYWORD=15

# Cron schedule (BKK time, aligned with Shopee flash sales)
CRON_SCRAPE_PRODUCTS=0 8,13,19,22 * * *

# -----------------------------------------------------------------------------
# DAILY BUDGET CAPS (kill switch)
# -----------------------------------------------------------------------------
DAILY_LLM_BUDGET_USD=10
DAILY_VIDEO_GEN_BUDGET_USD=10
DAILY_IMAGE_GEN_BUDGET_USD=3
DAILY_VOICE_GEN_BUDGET_USD=2

# -----------------------------------------------------------------------------
# FEATURE FLAGS (default off — enable per sprint)
# -----------------------------------------------------------------------------
FEATURE_TIKTOK_AUTO_POST=false        # Sprint 8 (after API approve)
FEATURE_META_AUTO_POST=false          # Sprint 4-5
FEATURE_AI_BRAIN=false                # Sprint 9-10 (after data warm-up)
FEATURE_PROMO_HUNTER=false            # Sprint 11
FEATURE_AUTO_TRANSLATE=false          # Sprint 12

# -----------------------------------------------------------------------------
# DEBUG
# -----------------------------------------------------------------------------
DEBUG_DRY_RUN=false                   # true = no real posts, no real spend
