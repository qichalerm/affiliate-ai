# =============================================================================
# affiliate-ai — Environment Variables (template)
# Copy to .env and fill in real values. Never commit .env (it's gitignored).
# Set permissions to 600 after creating: chmod 600 .env
# See docs/SETUP.md for what each variable does and where to obtain it.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
DOMAIN_NAME=example.com               # your registered domain
NODE_ENV=development                  # development | production
LOG_LEVEL=info                        # debug | info | warn | error
TIMEZONE=Asia/Bangkok

# -----------------------------------------------------------------------------
# DATABASE (Postgres 16+)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://botuser:CHANGE_ME@localhost:5432/affiliate?sslmode=disable
DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# AFFILIATE PROGRAMS
# -----------------------------------------------------------------------------
# Shopee Affiliate (https://affiliate.shopee.co.th/)
SHOPEE_AFFILIATE_ID=                  # numeric affiliate ID
SHOPEE_API_KEY=                       # Open Affiliate API App ID (apply at /open_api)
SHOPEE_API_SECRET=                    # Open Affiliate API App Secret
SHOPEE_TRACKING_ID=                   # optional custom sub-id

# TikTok Shop Affiliate (optional, https://affiliate.tiktok.com/)
TIKTOK_SHOP_AFFILIATE_ID=
TIKTOK_SHOP_API_KEY=

# -----------------------------------------------------------------------------
# DATA SOURCES
# -----------------------------------------------------------------------------
# Apify — required for Shopee scraping
APIFY_TOKEN=
APIFY_ACTOR_SHOPEE=xtracto/shopee-scraper
APIFY_MEMORY_MB=2048
APIFY_DAILY_BUDGET_USD=2.0

# Optional: TikTok Shop scraper (no-op until set; pick from apify.com/store)
TIKTOK_SHOP_ACTOR_ID=

# -----------------------------------------------------------------------------
# AI / CONTENT GENERATION
# -----------------------------------------------------------------------------
# Anthropic Claude (required — translations + variant generation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
ANTHROPIC_MODEL_PRO=claude-opus-4-7

# ElevenLabs (optional — voice for TikTok videos)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v3

# Image generation (optional)
REPLICATE_API_TOKEN=                  # Flux models
FLUX_API_KEY=

# Video generation (optional, defaults to ffmpeg slideshow)
KLING_API_KEY=
SORA_API_KEY=
RUNWAY_API_KEY=

# Auto-captions (optional)
SUBMAGIC_API_KEY=

# -----------------------------------------------------------------------------
# WEB / DEPLOYMENT
# -----------------------------------------------------------------------------
# Cloudflare (required for static-site auto-deploy + click tracking tunnel)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=                 # scopes: Pages:Edit + DNS:Edit + Tunnel:Edit
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PAGES_PROJECT=affiliate-ai

# Public site config
SITE_DOMAIN=example.com               # used in canonical URLs, sitemaps, hreflang
SITE_NAME=Affiliate AI
SITE_OUT_DIR=./dist
AUTO_DEPLOY_AFTER_REBUILD=true
SITE_REBUILD_DEBOUNCE_MS=300000       # coalesce N rebuild requests into 1 build

# Cloudflare R2 (optional — asset storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=affiliate-assets

# GitHub (optional — for git-push automation, not required to run)
GITHUB_TOKEN=
GITHUB_REPO=

# -----------------------------------------------------------------------------
# SEO
# -----------------------------------------------------------------------------
# Google Search Console (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_SEARCH_CONSOLE_PROPERTY=sc-domain:example.com

# Bing IndexNow (optional — auto-derived from SITE_DOMAIN if blank)
BING_INDEXNOW_KEY=

# -----------------------------------------------------------------------------
# SOCIAL CHANNELS
# -----------------------------------------------------------------------------
# Meta (Facebook + Instagram) — Graph API v21+
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=               # long-lived (60-day) Page Token
META_INSTAGRAM_BUSINESS_ID=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=                  # 24h expiry, refresh with refresh_token
TIKTOK_REFRESH_TOKEN=                 # 1-year expiry
TIKTOK_OPEN_ID=

# -----------------------------------------------------------------------------
# OPERATIONS
# -----------------------------------------------------------------------------
# Email (optional — operator alerts via Resend)
RESEND_API_KEY=
EMAIL_FROM=alerts@example.com
OPERATOR_EMAIL=

# Error tracking (optional)
SENTRY_DSN=

# -----------------------------------------------------------------------------
# NICHE / SCRAPE TUNING
# -----------------------------------------------------------------------------
PRIMARY_NICHE=all                     # all | it_gadget | beauty | home_appliance | sports_fitness | mom_baby | food_kitchen | fashion | car_garage
SCRAPE_KEYWORDS_PER_RUN=4
SCRAPE_PRODUCTS_PER_KEYWORD=15

# Cron schedule for scraping (default: 4×/day at Thai flash-sale hours)
CRON_SCRAPE_PRODUCTS=0 8,13,19,22 * * *

# -----------------------------------------------------------------------------
# DAILY BUDGET CAPS (kill-switch — exceed and that subsystem stops)
# -----------------------------------------------------------------------------
DAILY_LLM_BUDGET_USD=10
DAILY_VIDEO_GEN_BUDGET_USD=10
DAILY_IMAGE_GEN_BUDGET_USD=3
DAILY_VOICE_GEN_BUDGET_USD=2

# -----------------------------------------------------------------------------
# PER-CHANNEL POST CAPS (anti-bot detection — V2 vision)
# -----------------------------------------------------------------------------
DAILY_POSTS_FACEBOOK=5
DAILY_POSTS_INSTAGRAM=5
DAILY_POSTS_TIKTOK=3

# -----------------------------------------------------------------------------
# FEATURE FLAGS (enable as you activate each subsystem)
# -----------------------------------------------------------------------------
FEATURE_TIKTOK_AUTO_POST=false
FEATURE_META_AUTO_POST=false
FEATURE_AI_BRAIN=false
FEATURE_PROMO_HUNTER=false
FEATURE_AUTO_TRANSLATE=false

# -----------------------------------------------------------------------------
# CLICK-TRACKING REDIRECT SERVER
# -----------------------------------------------------------------------------
REDIRECT_SERVER_PORT=3001
REDIRECT_SERVER_HOST=127.0.0.1        # bind to localhost only — Cloudflare Tunnel reaches via CF network
INTERNAL_AUTH_SECRET=                 # generate with: openssl rand -hex 32

# -----------------------------------------------------------------------------
# DEBUG
# -----------------------------------------------------------------------------
DEBUG_DRY_RUN=false                   # true = simulate publishing, no real posts/spend
