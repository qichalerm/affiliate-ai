---
import type { RelatedLink } from "../lib/queries";
import type { Lang } from "../lib/i18n";
import { langFromPath, DEFAULT_LANG, getDict } from "../lib/i18n";

interface Props {
  links: RelatedLink[];
  title?: string;
  /** Used to keep related-link URLs in the same language as the host page. */
  lang?: Lang;
}

// Fall back to detecting language from the current URL when not passed explicitly.
const inferredLang = langFromPath(Astro.url.pathname) ?? DEFAULT_LANG;
const { links, lang = inferredLang } = Astro.props;
const t = getDict(lang);
const title = Astro.props.title ?? t.reviewPage.related;

if (!links || links.length === 0) return null;

const TYPE_PREFIX: Record<RelatedLink["type"], string> = {
  review: `/${lang}/รีวิว/`,
  comparison: `/${lang}/เปรียบเทียบ/`,
  best_of: `/${lang}/ของดี/`,
};

const TYPE_LABEL: Record<RelatedLink["type"], string> = {
  review: t.reviewPage.breadcrumb_reviews,
  comparison: t.comparisonPage.breadcrumb_compare,
  best_of: t.bestOfPage.breadcrumb_best,
};

// Color/style accents per content type — gives the section visual variety
// instead of a wall of identical cards.
const TYPE_STYLES: Record<RelatedLink["type"], { badge: string; icon: string; accent: string }> = {
  review: {
    badge: "bg-brand-50 text-brand-700 ring-brand-200 dark:bg-brand-900/40 dark:text-brand-300 dark:ring-brand-800",
    accent: "group-hover:text-brand-600",
    icon: `<svg viewBox="0 0 24 24" fill="none" class="h-3 w-3"><path d="M9 11h6m-6 4h4M7 4h10a2 2 0 0 1 2 2v14l-4-2-3 2-3-2-4 2V6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  comparison: {
    badge: "bg-violet-50 text-violet-700 ring-violet-200 dark:bg-violet-900/40 dark:text-violet-300 dark:ring-violet-800",
    accent: "group-hover:text-violet-600",
    icon: `<svg viewBox="0 0 24 24" fill="none" class="h-3 w-3"><path d="M9 6h11M9 12h11M9 18h11M5 6h.01M5 12h.01M5 18h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  },
  best_of: {
    // deal palette only has 50/100/400-700 — use rose-* defaults for ring/dark shades
    badge: "bg-deal-50 text-deal-700 ring-rose-200 dark:bg-rose-900/40 dark:text-rose-300 dark:ring-rose-800",
    accent: "group-hover:text-deal-600",
    icon: `<svg viewBox="0 0 24 24" fill="none" class="h-3 w-3"><path d="M8 21h8m-4-4v4M7 4h10v6a5 5 0 0 1-10 0V4Z M5 4H3v3a4 4 0 0 0 4 4 M19 4h2v3a4 4 0 0 1-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
};
---

<section class="mt-12 sm:mt-16">
  <div class="mb-5 sm:mb-6">
    <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
      {t.reviewPage.related ?? "Related"}
    </p>
    <h2 class="mt-1 text-xl font-bold text-ink-900 dark:text-ink-50 sm:text-2xl">
      {title}
    </h2>
  </div>

  <div class="grid gap-3 sm:gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {links.slice(0, 9).map((link) => {
      const style = TYPE_STYLES[link.type];
      return (
        <a
          href={`${TYPE_PREFIX[link.type]}${link.slug}`}
          class="card-interactive group overflow-hidden p-3 sm:p-4 flex gap-3 sm:gap-4"
        >
          {link.thumbnail ? (
            <div class="aspect-square w-20 sm:w-24 shrink-0 overflow-hidden rounded-xl bg-ink-100 dark:bg-ink-800">
              <img
                src={link.thumbnail}
                alt=""
                loading="lazy"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
              />
            </div>
          ) : (
            <div class="aspect-square w-20 sm:w-24 shrink-0 rounded-xl bg-gradient-to-br from-ink-100 to-ink-200 dark:from-ink-800 dark:to-ink-700 grid place-items-center text-2xl">
              📦
            </div>
          )}
          <div class="min-w-0 flex-1 flex flex-col">
            <span class={`badge ring-1 ring-inset w-fit mb-1.5 ${style.badge}`}>
              <Fragment set:html={style.icon} />
              <span>{TYPE_LABEL[link.type]}</span>
            </span>
            <h3 class={`line-clamp-2 text-sm font-semibold leading-snug text-ink-900 dark:text-ink-50 transition ${style.accent}`}>
              {link.title}
            </h3>
            {link.reason && (
              <p class="mt-1 line-clamp-2 text-xs text-ink-500 dark:text-ink-400">
                {link.reason}
              </p>
            )}
          </div>
        </a>
      );
    })}
  </div>
</section>
