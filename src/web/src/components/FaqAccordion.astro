---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FaqItem[];
  title?: string;
}

const { faqs, title = "คำถามที่พบบ่อย" } = Astro.props;

if (!faqs || faqs.length === 0) return null;
---

<section>
  <h2 class="text-lg sm:text-xl font-bold tracking-tight text-ink-900 dark:text-ink-50 mb-4 flex items-center gap-2">
    <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5 text-brand-500"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z M9.1 9a3 3 0 1 1 5 2.5c-.9.4-1.6 1.1-1.6 2.5 M12 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {title}
  </h2>

  <div class="space-y-2.5">
    {faqs.map((faq, i) => (
      <details class="card group p-0 overflow-hidden hover:border-brand-300 transition" open={i === 0}>
        <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-3 text-sm sm:text-base font-semibold text-ink-900 dark:text-ink-50 hover:bg-ink-50 dark:hover:bg-ink-800/40 transition">
          <span class="flex-1 text-balance">{faq.question}</span>
          <span class="shrink-0 grid h-7 w-7 place-items-center rounded-full bg-brand-50 text-brand-600 transition group-open:rotate-45 group-open:bg-brand-100 dark:bg-brand-900/40 dark:text-brand-400">
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
          </span>
        </summary>
        <div class="px-5 pb-5 pt-1 text-sm sm:text-[15px] leading-relaxed text-ink-700 dark:text-ink-300 border-t border-ink-100 dark:border-ink-800/70">
          <p class="mt-3">{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>
