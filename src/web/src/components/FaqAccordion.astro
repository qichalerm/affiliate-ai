---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FaqItem[];
  title?: string;
}

const { faqs, title = "คำถามที่พบบ่อย" } = Astro.props;

if (!faqs || faqs.length === 0) return null;
---

<section class="mt-10">
  <h2 class="mb-3 text-lg font-semibold">{title}</h2>
  <div class="space-y-2">
    {faqs.map((faq, i) => (
      <details class="card group" open={i === 0}>
        <summary class="cursor-pointer list-none font-medium text-slate-900 dark:text-slate-100">
          <div class="flex items-center justify-between gap-3">
            <span>{faq.question}</span>
            <span class="text-brand-600 transition group-open:rotate-45">+</span>
          </div>
        </summary>
        <p class="prose-th mt-3 text-sm leading-relaxed">
          {faq.answer}
        </p>
      </details>
    ))}
  </div>
</section>
