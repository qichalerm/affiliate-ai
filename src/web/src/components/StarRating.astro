---
import { compactCount } from "../lib/format";

interface Props {
  rating: number | null | undefined;
  count?: number | null | undefined;
  size?: "sm" | "md";
}

const { rating, count, size = "md" } = Astro.props;
const r = rating ?? 0;
const filled = Math.floor(r);
const half = r - filled >= 0.5;
const sizeCl = size === "sm" ? "text-xs" : "text-sm";
---

{rating != null && rating > 0 ? (
  <div class={`flex items-center gap-1 ${sizeCl} text-amber-500`} aria-label={`${rating} จาก 5`}>
    <span aria-hidden="true">
      {Array.from({ length: 5 }).map((_, i) => {
        if (i < filled) return "★";
        if (i === filled && half) return "☆"; // approximation
        return "☆";
      }).join("")}
    </span>
    <span class="font-medium text-slate-700 dark:text-slate-300">{rating.toFixed(1)}</span>
    {count != null && count > 0 && (
      <span class="text-slate-500">({compactCount(count)})</span>
    )}
  </div>
) : null}
