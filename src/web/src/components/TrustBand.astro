---
import type { Lang } from "../lib/i18n";
import { getDict } from "../lib/i18n";

interface Props {
  lang: Lang;
  productCount: number;
  lastUpdate?: Date | null;
  maxDiscountPercent?: number | null;
}

const { lang, productCount, lastUpdate, maxDiscountPercent } = Astro.props;
const t = getDict(lang);

function formatNumber(n: number): string {
  return new Intl.NumberFormat(lang === "th" ? "th-TH" : lang === "zh" ? "zh-CN" : lang === "ja" ? "ja-JP" : "en-US").format(n);
}

function formatTime(d: Date): string {
  const tz = lang === "th" ? "Asia/Bangkok" : lang === "zh" ? "Asia/Shanghai" : lang === "ja" ? "Asia/Tokyo" : "UTC";
  return new Intl.DateTimeFormat(lang === "th" ? "th-TH" : lang === "zh" ? "zh-CN" : lang === "ja" ? "ja-JP" : "en-US",
    { hour: "2-digit", minute: "2-digit", timeZone: tz }).format(d);
}

const lastUpdateStr = lastUpdate ? formatTime(lastUpdate) : "—";
---

<div class="container-page -mt-8 sm:-mt-12 relative z-10">
  <div class="card p-5 sm:p-6 grid grid-cols-2 gap-5 sm:gap-6 lg:grid-cols-4">
    <!-- Stat 1: Products tracked -->
    <div class="flex items-center gap-3">
      <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z M4 7l8 4 8-4 M12 11v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="min-w-0">
        <p class="stat-number text-xl font-bold text-ink-900 dark:text-ink-50 sm:text-2xl truncate">{formatNumber(productCount)}</p>
        <p class="text-xs text-ink-500 dark:text-ink-400 truncate">{t.trust.products_tracked}</p>
      </div>
    </div>

    <!-- Stat 2: Last update -->
    <div class="flex items-center gap-3">
      <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-success-50 text-success-700 dark:bg-success-700/20 dark:text-success-400">
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="M21 12a9 9 0 1 1-3-6.7L21 8 M21 3v5h-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="min-w-0">
        <p class="text-xl font-bold text-ink-900 dark:text-ink-50 sm:text-2xl truncate">{lastUpdateStr}</p>
        <p class="text-xs text-ink-500 dark:text-ink-400 truncate">{t.trust.last_update}</p>
      </div>
    </div>

    <!-- Stat 3: Free -->
    <div class="flex items-center gap-3">
      <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="M12 22s-7-4.5-7-12a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 7.5-7 12-7 12-1.4-.85-2.4-1.5-4-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="min-w-0">
        <p class="text-xl font-bold text-ink-900 dark:text-ink-50 sm:text-2xl">{t.trust.free}</p>
        <p class="text-xs text-ink-500 dark:text-ink-400 truncate">{t.trust.free_sub}</p>
      </div>
    </div>

    <!-- Stat 4: Verified affiliate / max discount -->
    {maxDiscountPercent && maxDiscountPercent > 0 ? (
      <div class="flex items-center gap-3">
        <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-deal-50 text-deal-600 dark:bg-deal-600/20">
          <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="m9 9 6 6 M15 9h.01 M9 15h.01 M19 5 5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <div class="min-w-0">
          <p class="stat-number text-xl font-bold text-deal-600 sm:text-2xl">−{Math.round(maxDiscountPercent * 100)}%</p>
          <p class="text-xs text-ink-500 dark:text-ink-400 truncate">{t.trust.max_discount}</p>
        </div>
      </div>
    ) : (
      <div class="flex items-center gap-3">
        <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-success-50 text-success-700 dark:bg-success-700/20 dark:text-success-400">
          <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="m9 12 2 2 4-4 M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-base font-bold text-ink-900 dark:text-ink-50 sm:text-lg leading-tight">{t.trust.verified}</p>
          <p class="text-xs text-ink-500 dark:text-ink-400 truncate">Shopee · Affiliate</p>
        </div>
      </div>
    )}
  </div>
</div>
