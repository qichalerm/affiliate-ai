---
import type { Lang } from "../lib/i18n";
import { getDict } from "../lib/i18n";

interface Props {
  lang: Lang;
  href: string; // affiliate URL or internal /รีวิว/{slug}
  external?: boolean; // true = goes to Shopee directly
  name: string;
  brand?: string | null;
  primaryImage?: string | null;
  /** Price in satang (THB × 100) */
  currentPrice: number | null;
  originalPrice?: number | null;
  discountPercent?: number | null; // 0..1
  rating?: number | null;
  ratingCount?: number | null;
  soldCount?: number | null;
  isMall?: boolean;
  isAllTimeLow?: boolean;
  /** ISO timestamp string for "updated X ago" */
  updatedAt?: string | null;
}

const props = Astro.props;
const t = getDict(props.lang);

function formatBaht(satang: number | null | undefined): string {
  if (!satang || satang <= 0) return "—";
  const baht = satang / 100;
  return new Intl.NumberFormat("th-TH", { maximumFractionDigits: 0 }).format(baht);
}

function compactCount(n: number | null | undefined): string {
  if (!n || n <= 0) return "";
  if (n >= 1000) return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k`;
  return String(n);
}

function timeAgo(iso: string | null | undefined, lang: Lang): string {
  if (!iso) return "";
  const diff = Date.now() - new Date(iso).getTime();
  const hours = Math.floor(diff / 3_600_000);
  if (hours < 1) {
    const mins = Math.max(1, Math.floor(diff / 60_000));
    return lang === "th" ? `${mins} นาที` : lang === "zh" ? `${mins}分钟` : lang === "ja" ? `${mins}分` : `${mins}m`;
  }
  if (hours < 24) {
    return lang === "th" ? `${hours} ชม.` : lang === "zh" ? `${hours}小时` : lang === "ja" ? `${hours}時間` : `${hours}h`;
  }
  const days = Math.floor(hours / 24);
  return lang === "th" ? `${days} วัน` : lang === "zh" ? `${days}天` : lang === "ja" ? `${days}日` : `${days}d`;
}

const discountPct = props.discountPercent ? Math.round(props.discountPercent * 100) : 0;
const updated = timeAgo(props.updatedAt, props.lang);
const linkRel = props.external ? "nofollow sponsored noopener" : undefined;
const linkTarget = props.external ? "_blank" : undefined;
---

<article class="card-interactive group relative flex flex-col overflow-hidden p-0">
  <a href={props.href} rel={linkRel} target={linkTarget} class="flex flex-col h-full">
    <!-- Image -->
    <div class="relative aspect-square overflow-hidden bg-ink-100 dark:bg-ink-800">
      {props.primaryImage ? (
        <img src={props.primaryImage} alt={props.name} loading="lazy"
             class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.04]"
             onerror="this.parentElement.innerHTML='<div class=\'flex h-full items-center justify-center text-3xl text-ink-300\'>📦</div>'" />
      ) : (
        <div class="flex h-full items-center justify-center text-3xl text-ink-300">📦</div>
      )}

      <!-- Discount badge top-left -->
      {discountPct > 0 && (
        <span class="absolute left-2.5 top-2.5 rounded-md bg-deal-600 px-2 py-0.5 text-xs font-bold text-white shadow-soft">
          −{discountPct}%
        </span>
      )}

      <!-- Mall badge top-right -->
      {props.isMall && (
        <span class="absolute right-2.5 top-2.5 rounded-md bg-ink-900/85 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
          Mall
        </span>
      )}
    </div>

    <!-- Body -->
    <div class="flex flex-1 flex-col p-3.5">
      {props.isAllTimeLow && (
        <span class="badge-success self-start mb-1.5">
          <svg viewBox="0 0 24 24" fill="none" class="h-3 w-3"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {t.card.all_time_low}
        </span>
      )}

      {props.brand && <p class="text-[10px] uppercase tracking-wider text-ink-500">{props.brand}</p>}
      <h3 class="line-clamp-2 min-h-[2.6rem] text-sm leading-tight font-medium text-ink-900 dark:text-ink-50">
        {props.name}
      </h3>

      <!-- Price block -->
      <div class="mt-2 flex items-baseline gap-2">
        <span class="price text-xl font-bold text-ink-900 dark:text-ink-50">฿{formatBaht(props.currentPrice)}</span>
        {props.originalPrice && props.currentPrice && props.originalPrice > props.currentPrice && (
          <span class="price text-xs text-ink-400 line-through">฿{formatBaht(props.originalPrice)}</span>
        )}
      </div>

      <!-- Meta row -->
      <div class="mt-2 flex items-center justify-between gap-2 text-[11px] text-ink-500">
        <div class="flex items-center gap-1.5">
          {props.rating && props.rating > 0 ? (
            <>
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5 text-warn-500"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z"/></svg>
              <span class="font-medium text-ink-700 dark:text-ink-300">{props.rating.toFixed(1)}</span>
              {props.ratingCount && <span class="text-ink-400">({compactCount(props.ratingCount)})</span>}
            </>
          ) : (
            <span class="text-ink-400">—</span>
          )}
        </div>
        {props.soldCount && props.soldCount > 0 && (
          <span>{t.card.sold} {compactCount(props.soldCount)}</span>
        )}
      </div>

      <!-- Footer: updated time + CTA -->
      <div class="mt-auto pt-3 flex items-center justify-between gap-2">
        {updated ? (
          <span class="flex items-center gap-1 text-[10px] text-ink-400">
            <svg viewBox="0 0 24 24" fill="none" class="h-3 w-3"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {updated}
          </span>
        ) : <span></span>}
        <span class="inline-flex items-center gap-1 text-xs font-semibold text-brand-600 group-hover:text-brand-700 dark:text-brand-400">
          {t.card.check_price}
          <svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5 transition group-hover:translate-x-0.5"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </div>
    </div>
  </a>
</article>
