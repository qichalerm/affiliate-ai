---
interface Props {
  platform: "shopee" | "lazada" | "tiktok_shop" | "jd_central" | "robinson";
  size?: "sm" | "md";
}

const { platform, size = "sm" } = Astro.props;

const labels: Record<Props["platform"], string> = {
  shopee: "Shopee",
  lazada: "Lazada",
  tiktok_shop: "TikTok Shop",
  jd_central: "JD",
  robinson: "Robinson",
};

const colors: Record<Props["platform"], string> = {
  shopee: "bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300",
  lazada: "bg-indigo-100 text-indigo-800 dark:bg-indigo-900/40 dark:text-indigo-300",
  tiktok_shop: "bg-slate-900 text-white",
  jd_central: "bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300",
  robinson: "bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-300",
};

const sizeCl = size === "sm" ? "text-[10px] px-1.5 py-0.5" : "text-xs px-2 py-1";
---

<span class={`inline-flex items-center rounded font-bold ${sizeCl} ${colors[platform]}`}>
  {labels[platform]}
</span>
