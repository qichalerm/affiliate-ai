---
interface Props {
  title?: string;
  description?: string;
  icon?: string;
  cta?: { label: string; href: string };
}

const {
  title = "ยังไม่มีข้อมูล",
  description = "ระบบกำลังเก็บข้อมูล กลับมาอีกครั้งในไม่ช้า",
  icon = "🌱",
  cta,
} = Astro.props;
---

<div class="card flex flex-col items-center gap-3 py-12 text-center">
  <p class="text-5xl">{icon}</p>
  <h3 class="text-xl font-bold">{title}</h3>
  <p class="max-w-md text-slate-600 dark:text-slate-400">{description}</p>
  {cta && (
    <a href={cta.href} class="btn-primary mt-2">{cta.label}</a>
  )}
</div>
