---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db } from "../../lib/db";
import { sql } from "drizzle-orm";

export const prerender = false;

const { token } = Astro.params;

let status: "ok" | "invalid" | "already" = "invalid";

if (token && token.length >= 16) {
  const rows = await db.execute<{ id: number; confirmed_at: Date | null }>(sql`
    SELECT id, confirmed_at FROM email_subscribers
     WHERE confirmation_token = ${token}
     LIMIT 1
  `);
  const row = rows[0];
  if (row) {
    if (row.confirmed_at) {
      status = "already";
    } else {
      await db.execute(sql`
        UPDATE email_subscribers
           SET confirmed_at = now()
         WHERE id = ${row.id}
      `);
      status = "ok";
    }
  }
}
---

<BaseLayout
  title={status === "ok" ? "ยืนยันอีเมลสำเร็จ" : status === "already" ? "อีเมลนี้ยืนยันแล้ว" : "ลิงก์ไม่ถูกต้อง"}
  noindex
>
  <section class="container-page py-20 text-center">
    {status === "ok" && (
      <div>
        <p class="text-6xl">✅</p>
        <h1 class="mt-4 text-2xl font-bold">ยืนยันอีเมลสำเร็จ</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-400">
          คุณจะได้รับดีลคัดสรรประจำสัปดาห์ทุกวันศุกร์<br>
          ถ้าไม่อยากรับเมื่อไหร่ คลิกลิงก์ "ยกเลิกการรับ" ในอีเมลแต่ละฉบับ
        </p>
        <a href="/" class="btn-primary mt-6 inline-block">กลับหน้าแรก</a>
      </div>
    )}
    {status === "already" && (
      <div>
        <p class="text-6xl">👍</p>
        <h1 class="mt-4 text-2xl font-bold">อีเมลนี้ยืนยันแล้ว</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-400">
          คุณอยู่ในรายชื่อสมาชิกอยู่แล้ว — ไม่ต้องทำอะไรเพิ่ม
        </p>
        <a href="/" class="btn-primary mt-6 inline-block">กลับหน้าแรก</a>
      </div>
    )}
    {status === "invalid" && (
      <div>
        <p class="text-6xl">❌</p>
        <h1 class="mt-4 text-2xl font-bold">ลิงก์ไม่ถูกต้อง</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-400">
          ลิงก์นี้อาจหมดอายุหรือถูกใช้ไปแล้ว ลองสมัครใหม่อีกครั้ง
        </p>
        <a href="/" class="btn-primary mt-6 inline-block">กลับหน้าแรก</a>
      </div>
    )}
  </section>
</BaseLayout>
