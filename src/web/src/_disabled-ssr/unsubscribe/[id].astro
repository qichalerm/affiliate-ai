---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db } from "../../lib/db";
import { sql } from "drizzle-orm";

export const prerender = false;

const { id } = Astro.params;

let status: "ok" | "invalid" = "invalid";
let email = "";

if (id && /^\d+$/.test(id)) {
  const rows = await db.execute<{ email: string; unsubscribed_at: Date | null }>(sql`
    SELECT email, unsubscribed_at FROM email_subscribers WHERE id = ${Number(id)}
    LIMIT 1
  `);
  const row = rows[0];
  if (row) {
    email = row.email;
    if (!row.unsubscribed_at) {
      await db.execute(sql`
        UPDATE email_subscribers SET unsubscribed_at = now() WHERE id = ${Number(id)}
      `);
    }
    status = "ok";
  }
}
---

<BaseLayout title="ยกเลิกการรับอีเมล" noindex>
  <section class="container-page py-20 text-center">
    {status === "ok" ? (
      <div>
        <p class="text-6xl">👋</p>
        <h1 class="mt-4 text-2xl font-bold">ยกเลิกการรับสำเร็จ</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-400">
          {email && <>เราจะไม่ส่งอีเมลถึง <strong>{email}</strong> อีก</>}<br>
          ถ้าอยากกลับมาสมัครใหม่เมื่อไหร่ ก็มาที่หน้าแรกได้เลย
        </p>
        <a href="/" class="btn-primary mt-6 inline-block">กลับหน้าแรก</a>
      </div>
    ) : (
      <div>
        <p class="text-6xl">❌</p>
        <h1 class="mt-4 text-2xl font-bold">ลิงก์ไม่ถูกต้อง</h1>
        <a href="/" class="btn-primary mt-6 inline-block">กลับหน้าแรก</a>
      </div>
    )}
  </section>
</BaseLayout>
