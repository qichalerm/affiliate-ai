---
/**
 * Root entry point — redirects to the user's preferred language.
 *
 * Detection order (in priority):
 *   1. Cloudflare Worker at edge (handles geo + cookie BEFORE this page is even served)
 *      → see workers/lang-redirect.ts
 *   2. Fallback (this page): client-side detection via cookie + navigator.language
 *      → ensures site works even when Worker isn't deployed
 *
 * Server emits a static HTML stub with <meta refresh> + <noscript> redirect to /en/
 * so search engines and JS-disabled browsers always land somewhere sensible.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PriceTH — Compare Shopee Thailand prices</title>
    <meta name="description" content="Compare Shopee Thailand prices with reviews and price history. Updated every 4 hours." />
    <link rel="alternate" hreflang="th" href="https://price-th.com/th/" />
    <link rel="alternate" hreflang="en" href="https://price-th.com/en/" />
    <link rel="alternate" hreflang="zh" href="https://price-th.com/zh/" />
    <link rel="alternate" hreflang="ja" href="https://price-th.com/ja/" />
    <link rel="alternate" hreflang="x-default" href="https://price-th.com/en/" />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href="https://price-th.com/en/" />

    <!-- Fallback: send unknown / no-JS clients to English after 0s -->
    <meta http-equiv="refresh" content="0; url=/en/" />

    <script is:inline>
      (function () {
        try {
          var SUPPORTED = ["th", "en", "zh", "ja"];
          // 1. Saved choice wins
          var saved = (document.cookie.match(/(^| )lang=([^;]+)/) || [])[2];
          if (saved && SUPPORTED.indexOf(saved) > -1) {
            location.replace("/" + saved + "/");
            return;
          }
          // 2. Browser language → map to supported
          var nav = (navigator.languages && navigator.languages[0]) || navigator.language || "en";
          nav = nav.toLowerCase();
          var lang = "en";
          if (nav.indexOf("th") === 0) lang = "th";
          else if (nav.indexOf("zh") === 0) lang = "zh";
          else if (nav.indexOf("ja") === 0) lang = "ja";
          // 3. Persist + redirect
          document.cookie = "lang=" + lang + "; path=/; max-age=31536000; SameSite=Lax";
          location.replace("/" + lang + "/");
        } catch (_) {
          location.replace("/en/");
        }
      })();
    </script>
  </head>
  <body style="font-family:system-ui,sans-serif;padding:2rem;text-align:center;color:#475569">
    <p>Loading PriceTH…</p>
    <noscript>
      <p><a href="/en/">Continue to PriceTH (English) →</a></p>
      <p><a href="/th/">เข้าสู่ PriceTH (ภาษาไทย) →</a></p>
    </noscript>
  </body>
</html>
