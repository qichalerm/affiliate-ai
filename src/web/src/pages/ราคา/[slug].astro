---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlatformBadge from "../../components/PlatformBadge.astro";
import StarRating from "../../components/StarRating.astro";
import { formatBaht } from "../../lib/format";
import { buildAffiliateUrl, platformLabel, type Platform } from "../../lib/affiliate-links";
import {
  getAllPublishedPriceCompare,
  getPriceCompareBySlug,
  type PriceCompareContent,
} from "../../lib/queries-price-compare";

export async function getStaticPaths() {
  let pages: Awaited<ReturnType<typeof getAllPublishedPriceCompare>> = [];
  try {
    pages = await getAllPublishedPriceCompare();
  } catch (err) {
    console.warn("price-compare getStaticPaths: db unavailable", err);
  }
  return pages.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const page = await getPriceCompareBySlug(slug!);
if (!page) return Astro.redirect("/404");

const c = (page.contentJson ?? {}) as PriceCompareContent;
const subId = `web_pricecompare_${page.slug.slice(0, 50)}`;

const cheapestItem = c.platforms[0];
---

<BaseLayout
  title={page.title}
  description={page.metaDescription ?? undefined}
  ogImage={page.ogImage ?? c.primaryImage ?? undefined}
>
  <article class="container-page py-8">
    <nav class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-brand-600">หน้าแรก</a>
      <span class="mx-2">/</span>
      <span>เปรียบเทียบราคา</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-[1fr_360px]">
      <div>
        {c.brand && <p class="text-sm uppercase tracking-wider text-brand-600">{c.brand}</p>}
        <h1 class="mt-1 text-2xl font-bold leading-tight sm:text-3xl">{page.h1 ?? page.title}</h1>

        <p class="prose-th mt-4">{c.intro}</p>

        {c.primaryImage && (
          <div class="mt-6 overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-800">
            <img src={c.primaryImage} alt={c.productName} class="aspect-square w-full object-cover" loading="eager" fetchpriority="high" />
          </div>
        )}

        <section class="mt-8">
          <h2 class="mb-3 text-lg font-semibold">ราคาในแต่ละแพลตฟอร์ม</h2>
          <div class="space-y-3">
            {c.platforms.map((p, idx) => {
              const isCheapest = idx === 0;
              const url = buildAffiliateUrl({
                platform: p.platform as Platform,
                externalId: p.externalId,
                shopExternalId: p.shopExternalId,
                subId: `${subId}_${idx}`,
              });
              return (
                <div class={`rounded-xl border p-4 ${isCheapest ? "border-emerald-300 bg-emerald-50 dark:border-emerald-800 dark:bg-emerald-900/20" : "border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900"}`}>
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex flex-1 items-center gap-3">
                      <PlatformBadge platform={p.platform as Platform} />
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="text-2xl font-bold">{formatBaht(p.price)}</span>
                          {isCheapest && c.platforms.length > 1 && (
                            <span class="rounded bg-emerald-600 px-2 py-0.5 text-xs font-bold text-white">ถูกสุด</span>
                          )}
                        </div>
                        {p.rating != null && p.rating > 0 && (
                          <div class="mt-1"><StarRating rating={p.rating} size="sm" /></div>
                        )}
                      </div>
                    </div>
                    {url && (
                      <a href={url} rel="nofollow sponsored noopener" target="_blank" class={`btn-${isCheapest ? "primary" : "ghost"} text-sm whitespace-nowrap`}>
                        ดูที่ {platformLabel(p.platform as Platform)} →
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        {c.bestNow && (
          <section class="mt-8 card border-l-4 border-l-emerald-500">
            <h2 class="mb-2 text-lg font-semibold">สรุป ณ ตอนนี้</h2>
            <p class="prose-th">{c.bestNow}</p>
          </section>
        )}

        <section class="mt-8 card">
          <h3 class="mb-2 text-base font-semibold">อ่านเพิ่มเติม</h3>
          <p class="text-sm">
            <a href={`/รีวิว/${c.primaryProductSlug}`} class="text-brand-600 hover:underline">
              รีวิว {c.productName} แบบเต็ม →
            </a>
          </p>
        </section>

        <p class="mt-8 text-xs text-slate-500">
          * ราคาอาจเปลี่ยนแปลง — ตรวจสอบในหน้าร้านก่อนสั่งซื้อทุกครั้ง
          เนื้อหาบางส่วนสรุปโดย AI จากข้อมูลจริง
          เราอาจได้รับค่าคอมเมื่อคุณซื้อผ่านลิงก์
        </p>
      </div>

      {cheapestItem && (
        <aside class="lg:sticky lg:top-6 lg:self-start">
          <div class="card border-l-4 border-l-emerald-500">
            <p class="text-xs uppercase tracking-wider text-emerald-600">ถูกที่สุดตอนนี้</p>
            <div class="mt-2 flex items-center gap-2">
              <PlatformBadge platform={cheapestItem.platform as Platform} />
              <span class="text-3xl font-bold">{formatBaht(cheapestItem.price)}</span>
            </div>
            {(() => {
              const url = buildAffiliateUrl({
                platform: cheapestItem.platform as Platform,
                externalId: cheapestItem.externalId,
                shopExternalId: cheapestItem.shopExternalId,
                subId: `${subId}_aside`,
              });
              return url ? (
                <a href={url} rel="nofollow sponsored noopener" target="_blank" class="btn-primary mt-4 w-full">
                  ซื้อที่ {platformLabel(cheapestItem.platform as Platform)} →
                </a>
              ) : null;
            })()}
            <p class="mt-3 text-center text-xs text-slate-500">
              ราคาอาจเปลี่ยน — เช็คอีกครั้งบนหน้าร้าน
            </p>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
