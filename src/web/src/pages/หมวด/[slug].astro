---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import {
  getAllActiveCategories,
  getCategoryBySlug,
  getTopProductsInCategory,
  getBestOfPagesInCategory,
  getSubcategories,
} from "../../lib/queries-categories";

export async function getStaticPaths() {
  let categories: Awaited<ReturnType<typeof getAllActiveCategories>> = [];
  try {
    categories = await getAllActiveCategories();
  } catch (err) {
    console.warn("category getStaticPaths: db unavailable", err);
  }
  // Only build pages for categories with at least 4 products
  return categories
    .filter((c) => c.productCount >= 4)
    .map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const category = await getCategoryBySlug(slug!);
if (!category) return Astro.redirect("/404");

const [products, bestOfPages, subcats] = await Promise.all([
  getTopProductsInCategory(category.id, 36),
  getBestOfPagesInCategory(category.id),
  getSubcategories(category.id),
]);

const title = `${category.nameTh} ยอดนิยม — รวมรีวิวและราคา`;
const description = `รวมรีวิว ${category.nameTh} ที่คนนิยม จัดอันดับจากยอดขาย คะแนนผู้ใช้ และความคุ้มค่า อัพเดทราคา Shopee + Lazada ทุกๆ 6 ชั่วโมง`;
---

<BaseLayout title={title} description={description}>
  <article class="container-page py-8">
    <nav class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-brand-600">หน้าแรก</a>
      <span class="mx-2">/</span>
      <span>{category.nameTh}</span>
    </nav>

    <h1 class="text-3xl font-bold sm:text-4xl">{category.nameTh}</h1>
    <p class="mt-2 max-w-2xl text-slate-600 dark:text-slate-400">
      {description}
    </p>

    {bestOfPages.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-3 text-xl font-bold">รวมรายการคัดสรร</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {bestOfPages.map((b) => (
            <a
              href={`/ของดี/${b.slug}`}
              class="card group transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <p class="text-xs uppercase tracking-wide text-brand-600">{b.variant ?? "best"}</p>
              <h3 class="mt-1 line-clamp-2 text-sm font-medium leading-snug group-hover:text-brand-600">
                {b.title}
              </h3>
            </a>
          ))}
        </div>
      </section>
    )}

    {subcats.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-3 text-xl font-bold">หมวดย่อย</h2>
        <div class="flex flex-wrap gap-2">
          {subcats.map((sc) => (
            <a
              href={`/หมวด/${sc.slug}`}
              class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-700 transition hover:border-brand-500 hover:text-brand-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
            >
              {sc.nameTh} {sc.productCount > 0 && <span class="text-slate-500">({sc.productCount})</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-10">
      <h2 class="mb-3 text-xl font-bold">สินค้ายอดนิยม</h2>
      {products.length > 0 ? (
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {products.map((p) => (
            <ProductCard
              slug={p.slug}
              name={p.name}
              brand={p.brand}
              primaryImage={p.primaryImage}
              currentPrice={p.currentPrice}
              originalPrice={p.originalPrice}
              discountPercent={p.discountPercent}
              rating={p.rating}
              ratingCount={p.ratingCount}
              soldCount={p.soldCount}
              isMall={p.isMall}
            />
          ))}
        </div>
      ) : (
        <p class="text-slate-500">ยังไม่มีรีวิวสินค้าในหมวดนี้ ระบบกำลังเก็บข้อมูล</p>
      )}
    </section>
  </article>
</BaseLayout>
