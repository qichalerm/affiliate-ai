---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCardV2 from "../../components/ProductCardV2.astro";
import EmptyState from "../../components/EmptyState.astro";
import {
  getAllActiveCategories,
  getCategoryBySlug,
  getTopProductsInCategory,
  getBestOfPagesInCategory,
  getSubcategories,
} from "../../lib/queries-categories";
import { bestProductLink } from "../../lib/affiliate-links";

export async function getStaticPaths() {
  let categories: Awaited<ReturnType<typeof getAllActiveCategories>> = [];
  try {
    categories = await getAllActiveCategories();
  } catch (err) {
    console.warn("category getStaticPaths: db unavailable", err);
  }
  // Build a page for any category with at least one product (was >=4, but Apify
  // scrapes don't always populate category_id so we'd lose 90% of categories).
  return categories
    .filter((c) => c.productCount >= 1)
    .map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const category = await getCategoryBySlug(slug!);
if (!category) return Astro.redirect("/404");

const [products, bestOfPages, subcats] = await Promise.all([
  getTopProductsInCategory(category.id, 60),
  getBestOfPagesInCategory(category.id),
  getSubcategories(category.id),
]);

const productsWithLinks = products.map((p) => ({
  p,
  link: bestProductLink({
    hasReviewPage: p.hasReviewPage,
    slug: p.slug,
    platform: p.platform,
    externalId: p.externalId,
    shopExternalId: p.shopExternalId,
    subId: `cat_${slug}`,
  }),
}));

const title = `${category.nameTh} ยอดนิยม — รวมรีวิวและราคา | PriceTH`;
const description = `รวมรีวิวสินค้าหมวด ${category.nameTh} จัดอันดับจากยอดขาย คะแนนผู้ใช้ และส่วนลด อัปเดตจาก Shopee ทุก 4 ชั่วโมง`;
---

<BaseLayout title={title} description={description} lang="th">
  <article class="container-page py-8 sm:py-12">
    <nav class="mb-4 text-sm text-ink-500">
      <a href="/th/" class="hover:text-brand-600">หน้าแรก</a>
      <span class="mx-2">/</span>
      <a href="/th/categories/" class="hover:text-brand-600">หมวดสินค้า</a>
      <span class="mx-2">/</span>
      <span class="text-ink-700">{category.nameTh}</span>
    </nav>

    <header class="mb-8">
      <p class="section-eyebrow">หมวดสินค้า</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 dark:text-ink-50">{category.nameTh}</h1>
      <p class="mt-3 text-base text-ink-600 dark:text-ink-400 max-w-2xl">{description}</p>
    </header>

    {subcats.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-ink-500">หมวดย่อย</h2>
        <div class="flex flex-wrap gap-2">
          {subcats.map((sc) => (
            <a href={`/หมวด/${sc.slug}`}
               class="inline-flex items-center gap-1.5 rounded-full border border-ink-200 bg-white px-3.5 py-1.5 text-sm text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700 dark:border-ink-800 dark:bg-ink-900 dark:text-ink-200">
              {sc.nameTh}
              {sc.productCount > 0 && <span class="text-ink-400 text-xs">({sc.productCount})</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {bestOfPages.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 text-xl font-bold text-ink-900 dark:text-ink-50">รวมรายการคัดสรร</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {bestOfPages.map((b) => (
            <a href={`/ของดี/${b.slug}`}
               class="card-interactive p-4">
              <p class="text-[10px] uppercase tracking-wider text-brand-600">{b.variant ?? "best"}</p>
              <h3 class="mt-1 line-clamp-2 text-sm font-semibold leading-snug">{b.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="mb-5 text-xl font-bold text-ink-900 dark:text-ink-50">
        สินค้ายอดนิยม
        {products.length > 0 && <span class="ml-2 text-sm font-normal text-ink-500">({products.length})</span>}
      </h2>
      {productsWithLinks.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4">
          {productsWithLinks.map(({ p, link }) => (
            <ProductCardV2
              lang="th"
              href={link.href}
              external={link.external}
              name={p.name}
              brand={p.brand}
              primaryImage={p.primaryImage}
              currentPrice={p.currentPrice}
              originalPrice={p.originalPrice}
              discountPercent={p.discountPercent}
              rating={p.rating}
              ratingCount={p.ratingCount}
              soldCount={p.soldCount}
              isMall={p.isMall}
            />
          ))}
        </div>
      ) : (
        <EmptyState icon="🌱" title="ยังไม่มีสินค้าในหมวดนี้" description="ระบบกำลังเก็บข้อมูลรอบใหม่ — รออัปเดตในไม่กี่ชั่วโมงข้างหน้า" />
      )}
    </section>
  </article>
</BaseLayout>
