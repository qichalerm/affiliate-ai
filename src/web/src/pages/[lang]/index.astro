---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import TrustBand from "../../components/TrustBand.astro";
import ProductCardV2 from "../../components/ProductCardV2.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getTopProducts, getDealsToday } from "../../lib/queries";
import { getAllActiveCategories } from "../../lib/queries-categories";
import { getSiteStats } from "../../lib/queries-stats";
import { type Lang, getDict, localePath, SUPPORTED_LANGS } from "../../lib/i18n";
import { bestProductLink } from "../../lib/affiliate-links";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getDict(lang);

let topProducts: Awaited<ReturnType<typeof getTopProducts>> = [];
let deals: Awaited<ReturnType<typeof getDealsToday>> = [];
let categories: Awaited<ReturnType<typeof getAllActiveCategories>> = [];
let stats = { productCount: 0, lastUpdate: null as Date | null, maxDiscountPercent: null as number | null };

try {
  [topProducts, deals, categories, stats] = await Promise.all([
    getTopProducts(12),
    getDealsToday(8),
    getAllActiveCategories(),
    getSiteStats(),
  ]);
} catch (err) {
  console.warn("[lang]/index: data load failed", err);
}

// Top-level categories with content
const topCategories = categories.filter((c) => c.depth <= 1 && c.productCount >= 1).slice(0, 12);

// Build category name lookup based on lang (TH master, fallback to TH)
const catName = (c: typeof categories[0]): string => {
  return c.nameTh ?? c.slug;
};

// Pre-compute card links (Astro JSX doesn't allow IIFE inside .map())
const dealsWithLinks = deals.map((p) => ({
  p,
  link: bestProductLink({
    hasReviewPage: p.hasReviewPage, slug: p.slug, platform: p.platform,
    externalId: p.externalId, shopExternalId: p.shopExternalId, subId: `homepage_deals_${lang}`,
  }),
}));
const topProductsWithLinks = topProducts.map((p) => ({
  p,
  link: bestProductLink({
    hasReviewPage: p.hasReviewPage, slug: p.slug, platform: p.platform,
    externalId: p.externalId, shopExternalId: p.shopExternalId, subId: `homepage_top_${lang}`,
  }),
}));
---

<BaseLayout lang={lang}>
  <!-- Hero -->
  <Hero lang={lang} />

  <!-- Trust band overlapping into next section -->
  <TrustBand
    lang={lang}
    productCount={stats.productCount}
    lastUpdate={stats.lastUpdate}
    maxDiscountPercent={stats.maxDiscountPercent}
  />

  <!-- Hot deals -->
  {deals.length > 0 && (
    <section class="container-page py-14 sm:py-20">
      <div class="flex items-end justify-between mb-6 sm:mb-8">
        <div>
          <p class="section-eyebrow">{t.sections.hot_deals_eyebrow}</p>
          <h2 class="section-title">🔥 {t.sections.hot_deals_title}</h2>
          <p class="section-sub max-w-2xl">{t.sections.hot_deals_sub}</p>
        </div>
        <a href={localePath(lang, "/best")} class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700">
          {t.sections.view_all}
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4">
        {dealsWithLinks.map(({ p, link }) => (
          <ProductCardV2
            lang={lang}
            href={link.href}
            external={link.external}
            name={p.name}
            brand={p.brand}
            primaryImage={p.primaryImage}
            currentPrice={p.currentPrice}
            originalPrice={p.originalPrice}
            discountPercent={p.discountPercent}
            rating={p.rating}
            ratingCount={p.ratingCount}
            soldCount={p.soldCount}
            isMall={p.isMall}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Categories -->
  {topCategories.length > 0 && (
    <section class="container-page pb-14 sm:pb-20">
      <div class="mb-6 sm:mb-8">
        <p class="section-eyebrow">{t.sections.categories_eyebrow}</p>
        <h2 class="section-title">{t.sections.categories_title}</h2>
      </div>
      <div class="grid grid-cols-3 gap-2.5 sm:gap-3 md:grid-cols-4 lg:grid-cols-6">
        {topCategories.map((c) => (
          <a href={`${localePath(lang, "/หมวด")}/${c.slug}`}
             class="card-interactive group flex flex-col items-center gap-2 p-4 text-center">
            <div class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600 transition group-hover:bg-brand-100 dark:bg-brand-900/30 dark:text-brand-400">
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><path d="M3 4h7v7H3zM14 4h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="text-sm font-semibold text-ink-900 dark:text-ink-50 line-clamp-1">{catName(c)}</h3>
            {c.productCount > 0 && (
              <p class="text-[11px] text-ink-500 dark:text-ink-500">{c.productCount}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Top products -->
  {topProducts.length > 0 ? (
    <section class="container-page pb-14 sm:pb-20">
      <div class="flex items-end justify-between mb-6 sm:mb-8">
        <div>
          <p class="section-eyebrow">{t.sections.top_eyebrow}</p>
          <h2 class="section-title">⭐ {t.sections.top_title}</h2>
        </div>
        <a href={localePath(lang, "/best")} class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700">
          {t.sections.view_all}
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4">
        {topProductsWithLinks.map(({ p, link }) => (
          <ProductCardV2
            lang={lang}
            href={link.href}
            external={link.external}
            name={p.name}
            brand={p.brand}
            primaryImage={p.primaryImage}
            currentPrice={p.currentPrice}
            originalPrice={p.originalPrice}
            discountPercent={p.discountPercent}
            rating={p.rating}
            ratingCount={p.ratingCount}
            soldCount={p.soldCount}
            isMall={p.isMall}
          />
        ))}
      </div>
    </section>
  ) : (
    <section class="container-page pb-14 sm:pb-20">
      <EmptyState icon="🌱" title={t.empty.title} description={t.empty.desc} />
    </section>
  )}
</BaseLayout>
