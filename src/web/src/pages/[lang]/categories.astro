---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getAllActiveCategories } from "../../lib/queries-categories";
import { type Lang, getDict, SUPPORTED_LANGS, interpolate, localePath, localizedName } from "../../lib/i18n";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getDict(lang);

let categories: Awaited<ReturnType<typeof getAllActiveCategories>> = [];
try {
  categories = await getAllActiveCategories();
} catch (err) {
  console.warn("/categories load failed", err);
}

// Show every active category (any depth) sorted by product count.
// Hides totally-empty categories so we don't link users to a 0-results page.
const all = categories
  .filter((c) => c.productCount > 0)
  .sort((a, b) => b.productCount - a.productCount);

const roots = categories.filter((c) => c.depth === 0).sort((a, b) => b.productCount - a.productCount);
---

<BaseLayout lang={lang} title={`${t.categories.title} — ${t.site.brand}`} description={t.categories.subtitle}>
  <section class="container-page py-10 sm:py-14">
    <p class="section-eyebrow">{t.nav.categories}</p>
    <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 dark:text-ink-50">
      {t.categories.title}
    </h1>
    <p class="mt-3 text-base text-ink-600 dark:text-ink-400 max-w-2xl">{t.categories.subtitle}</p>
  </section>

  {all.length === 0 ? (
    <section class="container-page pb-16">
      <EmptyState icon="🌱" title={t.empty.title} description={t.empty.desc} />
    </section>
  ) : (
    <>
      {roots.length > 0 && (
        <section class="container-page pb-12">
          <h2 class="mb-4 text-lg font-bold text-ink-900 dark:text-ink-50">
            {lang === "th" ? "หมวดหลัก" : lang === "zh" ? "主分类" : lang === "ja" ? "メインカテゴリー" : "Main categories"}
          </h2>
          <div class="grid grid-cols-2 gap-2.5 sm:gap-3 md:grid-cols-3 lg:grid-cols-4">
            {roots.map((c) => (
              <a href={`/${lang}/หมวด/${c.slug}`}
                 class="card-interactive flex items-center gap-3 p-4">
                <div class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
                  <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6"><path d="M3 4h7v7H3zM14 4h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z" stroke="currentColor" stroke-width="2"/></svg>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-ink-900 dark:text-ink-50 truncate">{localizedName(c, lang)}</p>
                  <p class="text-[11px] text-ink-500">{interpolate(t.categories.products_count, { n: c.productCount })}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="container-page pb-16">
        <h2 class="mb-4 text-lg font-bold text-ink-900 dark:text-ink-50">
          {lang === "th" ? `หมวดทั้งหมด (${all.length})` : lang === "zh" ? `全部分类 (${all.length})` : lang === "ja" ? `全カテゴリー (${all.length})` : `All categories (${all.length})`}
        </h2>
        <div class="grid grid-cols-2 gap-2 sm:gap-2.5 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
          {all.map((c) => (
            <a href={`/${lang}/หมวด/${c.slug}`}
               class="card-interactive flex items-center gap-2.5 p-3">
              <div class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-ink-100 text-ink-600 dark:bg-ink-800 dark:text-ink-400">
                <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-semibold text-ink-900 dark:text-ink-50 truncate">{localizedName(c, lang)}</p>
                <p class="text-[10px] text-ink-500">{c.productCount}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </>
  )}
</BaseLayout>
