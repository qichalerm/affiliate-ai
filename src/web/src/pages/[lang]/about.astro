---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type Lang, getDict, SUPPORTED_LANGS } from "../../lib/i18n";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = getDict(lang);
---

<BaseLayout lang={lang} title={`${t.about.title} — ${t.site.brand}`} description={t.about.lead}>
  <article class="container-page py-12 sm:py-20 max-w-3xl">
    <header class="mb-10">
      <p class="section-eyebrow">{t.nav.about}</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-ink-900 dark:text-ink-50 text-balance">
        {t.about.title}
      </h1>
      <p class="mt-4 text-lg text-ink-700 dark:text-ink-300 leading-relaxed text-balance">
        {t.about.lead}
      </p>
    </header>

    <!-- How it works -->
    <section class="card p-6 sm:p-8 mb-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><path d="M12 6v6l4 2 M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h2 class="text-xl font-bold text-ink-900 dark:text-ink-50">{t.about.h_how_title}</h2>
      </div>
      <ol class="space-y-3 text-ink-700 dark:text-ink-300">
        {t.about.h_how.map((line, idx) => (
          <li class="flex gap-3">
            <span class="shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700 dark:bg-brand-900 dark:text-brand-300">{idx + 1}</span>
            <span>{line}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- Data -->
    <section class="card p-6 sm:p-8 mb-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl bg-success-50 text-success-700 dark:bg-success-700/20 dark:text-success-400">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><ellipse cx="12" cy="6" rx="8" ry="3" stroke="currentColor" stroke-width="2"/><path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6 M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" stroke="currentColor" stroke-width="2"/></svg>
        </div>
        <h2 class="text-xl font-bold text-ink-900 dark:text-ink-50">{t.about.h_data_title}</h2>
      </div>
      <ul class="space-y-3 text-ink-700 dark:text-ink-300">
        {t.about.h_data.map((line) => (
          <li class="flex gap-3">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5 mt-0.5 shrink-0 text-success-600"><path d="m5 12 5 5 9-11" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Money -->
    <section class="card p-6 sm:p-8 mb-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl bg-deal-50 text-deal-600 dark:bg-deal-600/20">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><path d="M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 1 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h2 class="text-xl font-bold text-ink-900 dark:text-ink-50">{t.about.h_money_title}</h2>
      </div>
      <p class="text-ink-700 dark:text-ink-300 leading-relaxed">{t.about.h_money}</p>
    </section>

    <!-- Promise -->
    <section class="card p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><path d="M12 22s-7-4.5-7-12a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 7.5-7 12-7 12-1.4-.85-2.4-1.5-4-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h2 class="text-xl font-bold text-ink-900 dark:text-ink-50">{t.about.h_promise_title}</h2>
      </div>
      <ul class="space-y-3 text-ink-700 dark:text-ink-300">
        {t.about.h_promise.map((line) => (
          <li class="flex gap-3">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5 mt-0.5 shrink-0 text-brand-600"><path d="m5 12 5 5 9-11" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </section>
  </article>
</BaseLayout>
