---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PriceTag from "../../../components/PriceTag.astro";
import StarRating from "../../../components/StarRating.astro";
import PlatformBadge from "../../../components/PlatformBadge.astro";
import RelatedLinks from "../../../components/RelatedLinks.astro";
import { compactCount } from "../../../lib/format";
import { buildAffiliateUrl, platformLabel } from "../../../lib/affiliate-links";
import {
  getAllPublishedBestOf,
  getBestOfBySlug,
  getProductSlugs,
  type BestOfContent,
} from "../../../lib/queries-comparison";
import type { RelatedLink } from "../../../lib/queries";
import { getDict, SUPPORTED_LANGS, type Lang } from "../../../lib/i18n";

export async function getStaticPaths() {
  let pages: Awaited<ReturnType<typeof getAllPublishedBestOf>> = [];
  try {
    pages = await getAllPublishedBestOf();
  } catch (err) {
    console.warn("best-of getStaticPaths: db unavailable", err);
  }
  return SUPPORTED_LANGS.flatMap((lang) =>
    pages.map((p) => ({ params: { lang, slug: p.slug } })),
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const t = getDict(lang);
const page = await getBestOfBySlug(slug);
if (!page) return Astro.redirect(`/${lang}/`);

const c = (page.contentJson ?? {}) as BestOfContent & { relatedLinks?: RelatedLink[] };
const productMeta = await getProductSlugs(c.items.map((i) => i.productId));
---

<BaseLayout
  lang={lang}
  title={page.title}
  description={page.metaDescription ?? undefined}
  ogImage={page.ogImage ?? undefined}
>
  <article class="container-page py-8">
    <nav class="mb-4 text-sm text-slate-500">
      <a href={`/${lang}/`} class="hover:text-brand-600">{t.nav.home}</a>
      <span class="mx-2">/</span>
      <a href={`/${lang}/best`} class="hover:text-brand-600">{t.bestOfPage.breadcrumb_best}</a>
      <span class="mx-2">/</span>
      <span>{c.categoryName}</span>
    </nav>

    <h1 class="text-2xl font-bold leading-tight sm:text-3xl">
      {page.h1 ?? page.title}
    </h1>

    <p class="prose-th mt-4 max-w-3xl">{c.intro}</p>

    <ol class="mt-8 space-y-4">
      {c.items.map((item) => {
        const meta = productMeta.get(item.productId);
        const reviewSlug = meta?.slug;
        const subId = `web_bestof_${page.slug.slice(0, 30)}_${item.rank}_${lang}`;
        return (
          <li class="card">
            <div class="grid gap-4 sm:grid-cols-[120px_1fr_auto] sm:items-center">
              <div class="relative aspect-square overflow-hidden rounded-lg bg-slate-100 dark:bg-slate-800">
                {item.primaryImage && (
                  <img src={item.primaryImage} alt={item.name} loading="lazy" class="h-full w-full object-cover" />
                )}
                <span class="absolute left-2 top-2 rounded-full bg-brand-600 px-2 py-0.5 text-[11px] font-bold text-white">
                  #{item.rank}
                </span>
              </div>

              <div>
                {item.brand && <p class="text-xs uppercase text-slate-500">{item.brand}</p>}
                <h2 class="text-base font-semibold leading-snug">
                  {reviewSlug ? (
                    <a href={`/${lang}/รีวิว/${reviewSlug}`} class="hover:text-brand-600">{item.name}</a>
                  ) : (
                    item.name
                  )}
                </h2>
                <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-slate-500">
                  <StarRating rating={item.rating} size="sm" />
                  {item.soldCount && <span>{t.card.sold} {compactCount(item.soldCount)}</span>}
                </div>
              </div>

              <div class="flex flex-col items-end gap-2">
                <PriceTag current={item.priceSatang} size="md" />
                {meta && (
                  <PlatformBadge platform={meta.platform} size="sm" />
                )}
                {meta && (() => {
                  const url = buildAffiliateUrl({
                    platform: meta.platform,
                    externalId: meta.externalId,
                    shopExternalId: meta.shopExternalId,
                    subId,
                  });
                  return url ? (
                    <a
                      href={url}
                      rel="nofollow sponsored noopener"
                      target="_blank"
                      class="btn-primary text-sm"
                    >
                      {t.card.check_price.replace("Shopee", platformLabel(meta.platform))} →
                    </a>
                  ) : null;
                })()}
              </div>
            </div>
          </li>
        );
      })}
    </ol>

    {c.tagline && (
      <p class="mt-10 max-w-3xl rounded-lg bg-slate-50 p-4 text-sm italic text-slate-700 dark:bg-slate-800/40 dark:text-slate-300">
        {c.tagline}
      </p>
    )}

    {c.relatedLinks && c.relatedLinks.length > 0 && (
      <RelatedLinks links={c.relatedLinks} />
    )}
  </article>
</BaseLayout>
