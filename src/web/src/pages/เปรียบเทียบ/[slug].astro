---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PriceTag from "../../components/PriceTag.astro";
import StarRating from "../../components/StarRating.astro";
import PlatformBadge from "../../components/PlatformBadge.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import { compactCount } from "../../lib/format";
import { buildAffiliateUrl, platformLabel } from "../../lib/affiliate-links";
import {
  getAllPublishedComparisons,
  getComparisonBySlug,
  type ComparisonContent,
} from "../../lib/queries-comparison";
import type { RelatedLink } from "../../lib/queries";

export async function getStaticPaths() {
  let pages: Awaited<ReturnType<typeof getAllPublishedComparisons>> = [];
  try {
    pages = await getAllPublishedComparisons();
  } catch (err) {
    console.warn("comparison getStaticPaths: db unavailable", err);
  }
  return pages.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const page = await getComparisonBySlug(slug!);
if (!page) return Astro.redirect("/404");

const c = (page.contentJson ?? {}) as ComparisonContent & { relatedLinks?: RelatedLink[] };
const subId = `web_compare_${page.slug.slice(0, 50)}`;

// Default platform to shopee for backward-compat with old comparison records
function platformOf(p: ComparisonContent["productA"]) {
  return p.platform ?? "shopee";
}
---

<BaseLayout
  title={page.title}
  description={page.metaDescription ?? undefined}
  ogImage={page.ogImage ?? undefined}
>
  <article class="container-page py-8">
    <nav class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-brand-600">หน้าแรก</a>
      <span class="mx-2">/</span>
      <span>เปรียบเทียบ</span>
    </nav>

    <h1 class="text-2xl font-bold leading-tight sm:text-3xl">{page.h1 ?? page.title}</h1>

    <p class="prose-th mt-4 max-w-3xl">{c.intro}</p>

    <!-- Side-by-side cards -->
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {[c.productA, c.productB].map((p, idx) => {
        const sub = `${subId}_${idx === 0 ? "a" : "b"}`;
        const platform = platformOf(p);
        const url = buildAffiliateUrl({
          platform,
          externalId: p.externalId,
          shopExternalId: p.shopExternalId,
          subId: sub,
        });
        return (
          <div class="card">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-wider text-brand-600">
                ตัวเลือก {idx === 0 ? "A" : "B"}
              </span>
              <PlatformBadge platform={platform} size="sm" />
            </div>
            {p.primaryImage && (
              <div class="my-3 aspect-square overflow-hidden rounded-lg bg-slate-100 dark:bg-slate-800">
                <img src={p.primaryImage} alt={p.name} loading="lazy" class="h-full w-full object-cover" />
              </div>
            )}
            {p.brand && <p class="text-xs uppercase text-slate-500">{p.brand}</p>}
            <h2 class="text-base font-semibold">
              <a href={`/รีวิว/${p.slug}`} class="hover:text-brand-600">{p.name}</a>
            </h2>
            <div class="mt-2"><PriceTag current={p.priceSatang} size="md" /></div>
            <div class="mt-1 flex items-center gap-3 text-xs text-slate-500">
              <StarRating rating={p.rating} count={p.ratingCount} size="sm" />
              {p.soldCount && <span>ขาย {compactCount(p.soldCount)}</span>}
              {p.shop.isMall && <span class="rounded bg-red-600 px-1.5 py-0.5 text-[10px] font-bold text-white">Mall</span>}
            </div>
            {url ? (
              <a
                href={url}
                rel="nofollow sponsored noopener"
                target="_blank"
                class="btn-primary mt-3 w-full text-sm"
              >
                ดูที่ {platformLabel(platform)} →
              </a>
            ) : (
              <p class="mt-3 text-xs text-slate-500">ลิงก์ affiliate ไม่พร้อม</p>
            )}
          </div>
        );
      })}
    </div>

    <!-- Comparison table -->
    {c.differences.length > 0 && (
      <section class="mt-10">
        <h2 class="mb-3 text-xl font-bold">เปรียบเทียบรายด้าน</h2>
        <div class="card overflow-x-auto p-0">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-800/40">
                <th class="px-4 py-3 text-left font-medium">ด้าน</th>
                <th class="px-4 py-3 text-center font-medium">ผู้ชนะ</th>
                <th class="px-4 py-3 text-left font-medium">หมายเหตุ</th>
              </tr>
            </thead>
            <tbody>
              {c.differences.map((d) => (
                <tr class="border-b border-slate-100 last:border-0 dark:border-slate-800">
                  <td class="px-4 py-3 font-medium">{d.aspect}</td>
                  <td class="px-4 py-3 text-center">
                    {d.winner === "a" && <span class="rounded bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">A</span>}
                    {d.winner === "b" && <span class="rounded bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">B</span>}
                    {d.winner === "tie" && <span class="rounded bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">เสมอ</span>}
                  </td>
                  <td class="px-4 py-3 text-slate-600 dark:text-slate-400">{d.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Best for -->
    <section class="mt-10 grid gap-4 md:grid-cols-2">
      {[
        { label: c.productA.name, slug: c.productA.slug, text: c.bestForA },
        { label: c.productB.name, slug: c.productB.slug, text: c.bestForB },
      ].map((x) => (
        <div class="card">
          <p class="text-xs uppercase tracking-wide text-slate-500">เหมาะสำหรับใคร</p>
          <h3 class="mt-1 text-base font-semibold">
            <a href={`/รีวิว/${x.slug}`} class="hover:text-brand-600">{x.label}</a>
          </h3>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">{x.text}</p>
        </div>
      ))}
    </section>

    <!-- Verdict -->
    <section class="mt-10 card border-l-4 border-l-brand-500">
      <h2 class="mb-2 text-lg font-semibold">สรุป</h2>
      <p class="prose-th">{c.verdict}</p>
    </section>

    {c.relatedLinks && c.relatedLinks.length > 0 && (
      <RelatedLinks links={c.relatedLinks} />
    )}

    <p class="mt-8 text-xs text-slate-500">
      * เปรียบเทียบจากข้อมูลจริง ณ วันที่ระบบดึงข้อมูล
      ราคาและสต็อกอาจเปลี่ยนแปลง — ตรวจสอบในหน้าร้านก่อนสั่งซื้อ
      เนื้อหาบางส่วนสรุปโดย AI เราอาจได้รับค่าคอมเมื่อคุณซื้อผ่านลิงก์ในเนื้อหา
    </p>
  </article>
</BaseLayout>
